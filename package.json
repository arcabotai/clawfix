{
  "name": "clawfix",
  "version": "0.9.0",
  "description": "AI-powered OpenClaw diagnostic and repair service",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.js",
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "test": "node --test",
    "prove:remediation": "node scripts/prove-remediation.mjs .",
    "validate:repairs": "node scripts/validate-repairs.mjs",
    "lab:create": "node scripts/blaxel-lab.mjs create",
    "lab:provision": "node scripts/blaxel-lab.mjs provision",
    "lab:status": "node scripts/blaxel-lab.mjs status",
    "lab:native": "node scripts/blaxel-native-evidence.mjs",
    "lab:stop": "node scripts/blaxel-lab.mjs stop",
    "lab:scenarios": "node scripts/blaxel-scenarios.mjs all"
  },
  "dependencies": {
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "nanoid": "^5.1.5",
    "pg": "^8.18.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@blaxel/core": "^0.3.3"
  }
}
